# ===========================================
# API KEYS POUR MODÈLES EXTERNES
# ===========================================

# Gemini (Google AI)
GEMINI_API_KEY=votre_clé_gemini_ici
# Obtenir sur: https://makersuite.google.com/app/apikey

# Groq
GROQ_API_KEY=votre_clé_groq_ici
# Obtenir sur: https://console.groq.com/keys

# OpenRouter
OPENROUTER_API_KEY=votre_clé_openrouter_ici
# Obtenir sur: https://openrouter.ai/keys

# ===========================================
# CONFIGURATION BLOCKCHAIN
# ===========================================
WEB3_PROVIDER=http://127.0.0.1:8545
CONTRACT_ADDRESS=votre_adresse_contrat_ici
BLOCKCHAIN_PRIVATE_KEY=votre_clé_privée_ici

# ===========================================
# CONFIGURATION APPLICATION
# ===========================================
APP_NAME="Smart City Building Analyzer"
DEBUG=True
MAX_IMAGE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif

# ===========================================
# CHEMIN DU MODÈLE LOCAL
# ===========================================
LOCAL_MODEL_PATH=../ml-models/saved_models/mobilenet_building_detector.h5
TFLITE_MODEL_PATH=../ml-models/saved_models/mobilenet_building_detector.tflite